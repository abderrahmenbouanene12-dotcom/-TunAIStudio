/* ============================================
   THEME & LANGUAGE SYSTEM
   ============================================ */
function applyLang() {
    document.documentElement.lang = lang;
    document.documentElement.dir = lang === 'ar' ? 'rtl' : 'ltr';
    document.getElementById('langSelect').value = lang;
    document.querySelectorAll('[data-i18n]').forEach(el => {
        const v = t(el.dataset.i18n);
        if(v) el.innerHTML = v;
    });
    document.querySelectorAll('[data-i18n-ph]').forEach(el => {
        const v = t(el.dataset.i18nPh);
        if(v) el.placeholder = v;
    });
    document.getElementById('themeBtn').textContent = theme === 'dark' ? t('darkMode') : t('lightMode');
    renderLessons();
    renderSnippets();
    updateDash();
}

function changeLang(l) {
    lang = l;
    localStorage.setItem('tunai_lang', l);
    applyLang();
    toast(`🌍 ${l === 'ar' ? 'العربية' : l === 'en' ? 'English' : 'Français'}`, 'success');
}

function toggleTheme() {
    theme = theme === 'dark' ? 'light' : 'dark';
    localStorage.setItem('tunai_theme', theme);
    applyTheme();
    toast(theme === 'dark' ? '🌙 Dark Mode' : '☀️ Light Mode', 'success');
}

function applyTheme() {
    document.documentElement.setAttribute('data-theme', theme);
    document.getElementById('themeBtn').textContent = theme === 'dark' ? t('darkMode') : t('lightMode');
}

