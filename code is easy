   PREMIUM SYSTEM
   ============================================ */
function showPremium() {
    document.getElementById('premiumModal').classList.add('visible');
}

function closePremium() {
    document.getElementById('premiumModal').classList.remove('visible');
}

function upgrade() {
    const u = JSON.parse(localStorage.getItem('tunai_user')||'null');
    if(!u) return;
    u.premium = true;
    localStorage.setItem('tunai_user', JSON.stringify(u));
    const users = JSON.parse(localStorage.getItem('tunai_users')||'[]');
    const idx = users.findIndex(x => x.email === u.email);
    if(idx >= 0) {
        users[idx].premium = true;
        localStorage.setItem('tunai_users', JSON.stringify(users));
    }
    closePremium();
    updateUI();
    updateUsage();
    toast(t('toastUpgrade'), 'success');
}

