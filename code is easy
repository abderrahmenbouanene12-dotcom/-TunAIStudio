function matchType(p) {
    p = p.toLowerCase();
    if(/ثعبان|snake/.test(p)) return 'لعبة ثعبان';
    if(/حاسبة|calculator/.test(p)) return 'آلة حاسبة';
    if(/مهام|todo|task/.test(p)) return 'قائمة مهام';
    if(/متجر|shop|store/.test(p)) return 'متجر';
    if(/تسجيل|دخول|login|signin/.test(p)) return 'نموذج تسجيل دخول';
    if(/شخصي|profile/.test(p)) return 'صفحة شخصية';
    if(/سيرة|cv|resume/.test(p)) return 'سيرة ذاتية';
    if(/معرض|gallery|صور/.test(p)) return 'معرض صور';
    if(/مطعم|restaurant|menu/.test(p)) return 'مطعم';
    if(/مدونة|blog/.test(p)) return 'مدونة';
    return p;
}

/* ============================================
   STATE MANAGEMENT
   ============================================ */
let curCode = '', curTitle = '';
const L_FREE = 5, L_PRO = 999999;

function getUsage() {
    const today = new Date().toDateString();
    const d = JSON.parse(localStorage.getItem('tunai_usage')||'{}');
    return d.date === today ? d : {date:today, count:0};
}

function updateUsage() {
    const u = JSON.parse(localStorage.getItem('tunai_user')||'null');
    const isPro = u && u.premium;
    const lim = isPro ? L_PRO : L_FREE;
    const usage = getUsage();
    document.getElementById('usageCount').textContent = usage.count;
    document.getElementById('usageLimit').textContent = isPro ? '∞' : lim;
    const pct = isPro ? 0 : (usage.count/lim)*100;
    const fill = document.getElementById('usageFill');
    fill.style.width = pct + '%';
    fill.className = 'usage-fill' + (pct>=80 ? ' danger' : pct>=60 ? ' warning' : '');
    document.getElementById('upgradeBtn').classList.toggle('hidden', isPro);
}

function canGenerate() {
    const u = JSON.parse(localStorage.getItem('tunai_user')||'null');
    if(!u) return false;
    if(u.premium) return true;
    return getUsage().count < L_FREE;
}

function incUsage() {
    const u = getUsage();
    u.count++;
    localStorage.setItem('tunai_usage', JSON.stringify(u));
    updateUsage();
}

/* ============================================
   AUTH SYSTEM
   ============================================ */
function openAuth(tab='login') {
    document.getElementById('authModal').classList.add('visible');
    switchAuth(tab);
}

function closeAuth() {
    document.getElementById('authModal').classList.remove('visible');
}

function switchAuth(tab, btn) {
    document.querySelectorAll('.auth-tab').forEach(t => t.classList.remove('active'));
    if(btn) btn.classList.add('active');
    else document.querySelector(`.auth-tab[onclick*="${tab}"]`)?.classList.add('active');
    document.getElementById('loginForm').classList.toggle('hidden', tab !== 'login');
    document.getElementById('signupForm').classList.toggle('hidden', tab !== 'signup');
}

function loginWithGoogle() {
    const user = {
        id: 'google_'+Date.now(),
        name: 'Google User',
        email: 'user@gmail.com',
        provider: 'google',
        verified: true,
        premium: false
    };
    localStorage.setItem('tunai_user', JSON.stringify(user));
    updateUI();
    closeAuth();
    toast(t('toastWelcome') + 'Google User!', 'success');
}

function doLogin() {
    const email = document.getElementById('loginEmail').value.trim();
    const pw = document.getElementById('loginPw').value;
    const users = JSON.parse(localStorage.getItem('tunai_users')||'[]');
    const u = users.find(x => x.email === email && x.password === pw);
    if(!u) { toast(t('toastWrongCreds'), 'error'); return; }
    if(!u.verified) { toast(t('toastVerify'), 'warning'); return; }
    localStorage.setItem('tunai_user', JSON.stringify(u));
    toast(t('toastWelcome') + u.name + '!', 'success');
    closeAuth();
    updateUI();
    updateUsage();
}

function doSignup() {
    const name = document.getElementById('signupName').value.trim();
    const email = document.getElementById('signupEmail').value.trim();
    const pw = document.getElementById('signupPw').value;
    if(pw.length < 8) { toast(t('toastPwShort'), 'error'); return; }
    const users = JSON.parse(localStorage.getItem('tunai_users')||'[]');
    if(users.find(x => x.email === email)) { toast(t('toastEmailExists'), 'error'); return; }
    const newUser = {id:Date.now(), name, email, password:pw, verified:true, premium:false};
    users.push(newUser);
    localStorage.setItem('tunai_users', JSON.stringify(users));
    localStorage.setItem('tunai_user', JSON.stringify(newUser));
    toast(t('toastVerified') + name + '!', 'success');
    closeAuth();
    updateUI();
    updateUsage();
}

function logout() {
    localStorage.removeItem('tunai_user');
    updateUI();
    updateUsage();
    toast(t('toastLogout'), 'success');
}

function updateUI() {
    const u = JSON.parse(localStorage.getItem('tunai_user')||'null');
    const btns = document.getElementById('authButtons');
    const info = document.getElementById('userInfo');
    const pro = document.getElementById('proBadge');
    if(u) {
        btns.style.display = 'none';
        info.classList.remove('hidden');
        document.getElementById('userName').textContent = u.name;
        document.getElementById('userAvatar').textContent = u.name.charAt(0).toUpperCase();
        pro.classList.toggle('hidden', !u.premium);
    } else {
        btns.style.display = 'flex';
        info.classList.add('hidden');
    }
}

