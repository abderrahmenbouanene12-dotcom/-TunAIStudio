   RENDER LESSONS
   ============================================ */
function renderLessons() {
    const container = document.getElementById('lessonsContainer');
    if(!container) return;
    const completed = JSON.parse(localStorage.getItem('tunai_lessons_completed')||'[]');
    const isAr = lang === 'ar';
    
    container.innerHTML = lessons.map(l => {
        const done = completed.includes(l.id);
        const title = isAr ? l.titleAr : l.title;
        const content = isAr ? l.contentAr : l.content;
        const exercise = isAr ? l.exerciseAr : l.exercise;
        
        return `
        <div class="lesson-card ${done?'completed':''}" id="lesson-${l.id}">
            <div class="lesson-num">${l.id}</div>
            <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:0.8rem;flex-wrap:wrap;gap:0.5rem">
                <h3 class="lesson-title">${title}</h3>
                <span class="lesson-badge ${l.level}">${l.level.toUpperCase()}</span>
            </div>
            <div class="lesson-content">${content}</div>
            <div class="lesson-grid">
                <div class="code-preview">
                    <div class="code-header">
                        <span>${t('codeLabel')}</span>
                        <button class="btn btn-ghost btn-sm" style="padding:2px 8px;font-size:0.7rem" onclick="navigator.clipboard.writeText(\`${l.code.replace(/`/g,'\\`').replace(/\\/g,'\\\\')}\`);toast('${t('toastCopy')}','success')">${t('copyCode')}</button>
                    </div>
                    <pre>${l.code.replace(/</g,'&lt;').replace(/>/g,'&gt;')}</pre>
                </div>
                <div class="live-preview">
                    <div class="preview-header" style="background:#f5f5f5;color:#666;border-bottom:1px solid #ddd">${t('previewLabel')}</div>
                    <iframe srcdoc="${l.code.replace(/"/g,'&quot;')}"></iframe>
                </div>
            </div>
            <div class="exercise"><strong>${t('exercise')}</strong> ${exercise}</div>
            <div class="lesson-actions">
                <button class="btn ${done?'btn-ghost':'btn-primary'} btn-sm" onclick="toggleLesson(${l.id})">
                    ${done ? t('completedLabel') : t('markComplete')}
                </button>
                <button class="btn btn-ghost btn-sm" onclick="scrollToNext(${l.id})">${t('nextLesson')}</button>
            </div>
        </div>`;
    }).join('');
    
    updateProgress();
}

function toggleLesson(id) {
    const completed = JSON.parse(localStorage.getItem('tunai_lessons_completed')||'[]');
    const idx = completed.indexOf(id);
    if(idx > -1) {
        completed.splice(idx, 1);
    } else {
        completed.push(id);
        toast('🎉 ' + t('completedLabel'), 'success');
    }
    localStorage.setItem('tunai_lessons_completed', JSON.stringify(completed));
    renderLessons();
}

function scrollToNext(id) {
    const next = document.getElementById('lesson-' + (id + 1));
    if(next) {
        next.scrollIntoView({behavior:'smooth', block:'start'});
    } else {
        toast('🏆 All lessons completed!', 'success');
    }
}

function updateProgress() {
    const completed = JSON.parse(localStorage.getItem('tunai_lessons_completed')||'[]');
    const pct = Math.round((completed.length / lessons.length) * 100);
    const el1 = document.getElementById('completedCount');
    const el2 = document.getElementById('progressPct');
    if(el1) el1.textContent = completed.length;
    if(el2) el2.textContent = pct + '%';
}

/* ============================================
   RENDER SNIPPETS - Enhanced
   ============================================ */
function renderSnippets() {
    const grid = document.getElementById('snippetsGrid');
    if(!grid) return;
    
    grid.innerHTML = snippets.map(s => {
        const levelClass = 'level-' + s.level;
        const levelText = s.level.charAt(0).toUpperCase() + s.level.slice(1);
        const previewCode = s.code.substring(0, 200).replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;').replace(/'/g,'&#39;');
        const tagsHtml = s.tags.map(tag => `<span class="snippet-tag">#${tag}</span>`).join('');
        
        return `
        <div class="snippet-card">
            <div class="snippet-header">
                <div class="snippet-icon">${s.icon}</div>
                <span class="snippet-level ${levelClass}">${levelText}</span>
            </div>
            <h3 class="snippet-title">${s.title}</h3>
            <p class="snippet-desc">${s.desc}</p>
            <div class="snippet-tags">${tagsHtml}</div>
            <div class="snippet-preview">
                <pre>${previewCode}...</pre>
            </div>
            <div class="snippet-actions">
                <button class="btn btn-ghost btn-sm" onclick="copySnippet(${s.id})">${t('copyCode')}</button>
                <button class="btn btn-primary btn-sm" onclick="viewSnippet(${s.id})">${t('viewCode')}</button>
            </div>
        </div>`;
    }).join('');
}

function copySnippet(id) {
    const snippet = snippets.find(s => s.id === id);
    if(!snippet) {
        toast('❌ Snippet not found', 'error');
        return;
    }
    
    if(navigator.clipboard && navigator.clipboard.writeText) {
        navigator.clipboard.writeText(snippet.code).then(() => {
            toast('✅ ' + t('toastCopy'), 'success');
            const s = JSON.parse(localStorage.getItem('tunai_stats')||'{}');
            s.copy = (s.copy || 0) + 1;
            localStorage.setItem('tunai_stats', JSON.stringify(s));
            updateDash();
        }).catch(() => {
            fallbackCopy(snippet.code);
        });
    } else {
        fallbackCopy(snippet.code);
    }
}

function viewSnippet(id) {
    const snippet = snippets.find(s => s.id === id);
    if(!snippet) return;
    
    curCode = snippet.code;
    curTitle = snippet.title;
    
    // Switch to TunAI tab and show the code
    const tunaiTab = document.querySelector('.tab[onclick*="tunai"]');
    if(tunaiTab) switchTab('tunai', tunaiTab);
    
    document.getElementById('aiTitle').textContent = '✨ ' + snippet.title;
    document.getElementById('aiCode').textContent = snippet.code;
    document.getElementById('aiPreview').srcdoc = snippet.code;
    document.getElementById('aiResult').classList.add('visible');
    
    toast('📂 Loaded: ' + snippet.title, 'success');
}

function fallbackCopy(text) {
    const textarea = document.createElement('textarea');
    textarea.value = text;
    textarea.style.position = 'fixed';
    textarea.style.opacity = '0';
    textarea.style.left = '-9999px';
    document.body.appendChild(textarea);
    textarea.select();
    try {
        document.execCommand('copy');
        toast('✅ ' + t('toastCopy'), 'success');
        const s = JSON.parse(localStorage.getItem('tunai_stats')||'{}');
        s.copy = (s.copy || 0) + 1;
        localStorage.setItem('tunai_stats', JSON.stringify(s));
        updateDash();
    } catch(e) {
        toast('❌ Copy failed', 'error');
    }
    document.body.removeChild(textarea);
}

/* ============================================
   CODE GENERATION
   ============================================ */
function generateCode() {
    const u = JSON.parse(localStorage.getItem('tunai_user')||'null');
    if(!u) {
        toast(t('toastLoginFirst'), 'warning');
        openAuth('login');
        return;
    }
    if(!canGenerate()) {
        toast(t('toastLimit'), 'warning');
        showPremium();
        return;
    }
    
    const input = document.getElementById('aiInput').value.trim();
    if(!input) {
        toast(t('toastType'), 'warning');
        return;
    }
    
    const btn = document.getElementById('genBtn');
    btn.disabled = true;
    btn.innerHTML = '<span class="spinner"></span>';
    
    setTimeout(() => {
        const type = matchType(input);
        const code = genTemplate(type);
        curCode = code;
        curTitle = type;
        
        document.getElementById('aiTitle').textContent = '✨ ' + type;
        document.getElementById('aiCode').textContent = code;
        document.getElementById('aiPreview').srcdoc = code;
        document.getElementById('aiResult').classList.add('visible');
        
        incUsage();
        
        const hist = JSON.parse(localStorage.getItem('tunai_history')||'[]');
        hist.unshift({q:input, t:type, d:Date.now()});
        if(hist.length > 20) hist.pop();
        localStorage.setItem('tunai_history', JSON.stringify(hist));
        
        const stats = JSON.parse(localStorage.getItem('tunai_stats')||'{}');
        stats.gen = (stats.gen || 0) + 1;
        localStorage.setItem('tunai_stats', JSON.stringify(stats));
        
        updateDash();
        toast(t('toastGen'), 'success');
        
        btn.disabled = false;
        btn.textContent = t('generate');
    }, 500);
}

function copyCode() {
    if(!curCode) return;
    navigator.clipboard.writeText(curCode).then(() => {
        const s = JSON.parse(localStorage.getItem('tunai_stats')||'{}');
        s.copy = (s.copy || 0) + 1;
        localStorage.setItem('tunai_stats', JSON.stringify(s));
        updateDash();
        toast(t('toastCopy'), 'success');
    });
}

function downloadCode() {
    if(!curCode) return;
    const blob = new Blob([curCode], {type:'text/html'});
    const a = document.createElement('a');
    a.href = URL.createObjectURL(blob);
    a.download = 'tunaistudio-generated.html';
    a.click();
    URL.revokeObjectURL(a.href);
    toast(t('toastDownload'), 'success');
}

function addFav() {
    if(!curCode) return;
    const f = JSON.parse(localStorage.getItem('tunai_fav')||'[]');
    if(f.find(x => x.title === curTitle)) {
        toast('⚠️ Already in favorites', 'warning');
        return;
    }
    f.unshift({id:Date.now(), title:curTitle, code:curCode, date:Date.now()});
    localStorage.setItem('tunai_fav', JSON.stringify(f));
    updateDash();
    toast(t('toastFav'), 'success');
}

/* ============================================
   DASHBOARD
   ============================================ */
function updateDash() {
    const s = JSON.parse(localStorage.getItem('tunai_stats')||'{}');
    const f = JSON.parse(localStorage.getItem('tunai_fav')||'[]');
    const h = JSON.parse(localStorage.getItem('tunai_history')||'[]');
    
    const el1 = document.getElementById('statGen');
    const el2 = document.getElementById('statFav');
    const el3 = document.getElementById('statCopy');
    const el4 = document.getElementById('statHist');
    if(el1) el1.textContent = s.gen || 0;
    if(el2) el2.textContent = f.length;
    if(el3) el3.textContent = s.copy || 0;
    if(el4) el4.textContent = h.length;
    
    const favList = document.getElementById('favList');
    if(favList) {
        if(f.length === 0) {
            favList.innerHTML = `<p class="empty-state">${t('noFav')}</p>`;
        } else {
            favList.innerHTML = f.slice(0, 10).map(x => `
                <div class="list-item">
                    <div class="list-item-info">
                        <div class="list-item-title">${x.title}</div>
                        <div class="list-item-meta">${new Date(x.date).toLocaleString()}</div>
                    </div>
                    <div class="list-item-actions">
                        <button class="btn btn-primary btn-sm" onclick="loadFav(${x.id})">📂</button>
                        <button class="btn btn-ghost btn-sm" onclick="rmFav(${x.id})" style="color:var(--danger)">🗑️</button>
                    </div>
                </div>
            `).join('');
        }
    }
    
    const histList = document.getElementById('histList');
    if(histList) {
        if(h.length === 0) {
            histList.innerHTML = `<p class="empty-state">${t('noHist')}</p>`;
        } else {
            histList.innerHTML = h.slice(0, 10).map(x => `
                <div class="list-item">
                    <div class="list-item-info">
                        <div class="list-item-title">${x.q}</div>
                        <div class="list-item-meta">${new Date(x.d).toLocaleString()}</div>
                    </div>
                    <button class="btn btn-ghost btn-sm" onclick="setAI('${x.q.replace(/'/g,"\\'")}')">🔁</button>
                </div>
            `).join('');
        }
    }
}

function loadFav(id) {
    const f = JSON.parse(localStorage.getItem('tunai_fav')||'[]');
    const x = f.find(y => y.id === id);
    if(!x) return;
    curCode = x.code;
    curTitle = x.title;
    document.getElementById('aiTitle').textContent = '✨ ' + x.title + ' (Favorite)';
    document.getElementById('aiCode').textContent = x.code;
    document.getElementById('aiPreview').srcdoc = x.code;
    document.getElementById('aiResult').classList.add('visible');
    const tb = document.querySelector('.tab[onclick*="tunai"]');
    if(tb) switchTab('tunai', tb);
    toast('📂 Loaded from favorites', 'success');
}

function rmFav(id) {
    const f = JSON.parse(localStorage.getItem('tunai_fav')||'[]');
    localStorage.setItem('tunai_fav', JSON.stringify(f.filter(x => x.id !== id)));
    updateDash();
    toast('🗑️ Removed', 'success');
}

function clearHistory() {
    if(confirm('Clear all history?')) {
        localStorage.removeItem('tunai_history');
        updateDash();
        toast('🗑️ History cleared', 'success');
    }
}

/* ============================================
   UI HELPERS
   ============================================ */
function switchTab(name, btn) {
    document.querySelectorAll('.tab').forEach(t => t.classList.remove('active'));
    document.querySelectorAll('.section').forEach(s => s.classList.remove('active'));
    btn.classList.add('active');
    document.getElementById(name + '-section').classList.add('active');
    if(name === 'dashboard') updateDash();
}

function setSearch(txt) {
    document.getElementById('heroInput').value = txt;
    moveToAI();
}

function setAI(txt) {
    document.getElementById('aiInput').value = txt;
    const tb = document.querySelector('.tab[onclick*="tunai"]');
    if(tb) switchTab('tunai', tb);
    setTimeout(generateCode, 200);
}

function moveToAI() {
    const txt = document.getElementById('heroInput').value.trim();
    if(!txt) return;
    document.getElementById('aiInput').value = txt;
    const tb = document.querySelector('.tab[onclick*="tunai"]');
    if(tb) switchTab('tunai', tb);
    setTimeout(generateCode, 300);
}

function toast(msg, type='success') {
    const el = document.createElement('div');
    el.className = 'toast ' + type;
    const icons = {
        success: '✅',
        error: '❌',
        warning: '⚠️',
        info: 'ℹ️'
    };
    el.innerHTML = `<span class="toast-icon">${icons[type] || '✅'}</span><span class="toast-message">${msg}</span>`;
    document.getElementById('toastContainer').appendChild(el);
    setTimeout(() => {
        el.style.opacity = '0';
        el.style.transition = 'opacity .3s';
        setTimeout(() => el.remove(), 300);
    }, 3000);
}

